# Database
# For local development: mongodb://localhost:27017/pharmaflow
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/pharmaflow?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/pharmaflow?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_jwt_secret_key_change_in_production

# Server
PORT=5000
NODE_ENV=development

# CORS
FRONTEND_URL=http://localhost:3000
